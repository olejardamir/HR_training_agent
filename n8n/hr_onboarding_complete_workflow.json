{
  "name": "HR Onboarding Agent - Complete v1",
  "nodes": [
    {
      "id": "webhook",
      "name": "Webhook - New Hire",
      "type": "n8n-nodes-base.webhook",
      "position": [250, 300],
      "parameters": {
        "path": "hr-onboarding",
        "httpMethod": "POST",
        "responseMode": "responseNode"
      }
    },
    {
      "id": "normalize-input",
      "name": "Normalize Input",
      "type": "n8n-nodes-base.set",
      "position": [450, 300],
      "parameters": {
        "assignments": {
          "assignments": [
            { "name": "employee_id", "value": "={{ $json.body.employee_id || $json.employee_id || 'emp_001' }}" },
            { "name": "api_base_url", "value": "={{ $env.API_BASE_URL || 'http://api:8000' }}" },
            { "name": "correlation_id", "value": "={{ $json.body.correlation_id || ('corr_' + Date.now()) }}" },
            { "name": "auto_approve", "value": "={{ $json.body.auto_approve_manager ?? true }}" },
            { "name": "selected_systems", "value": "={{ $json.body.selected_systems || ['Salesforce','Gong','Sales Slack Channels'] }}" }
          ]
        }
      }
    },
    {
      "id": "start-session",
      "name": "Start Onboarding Session",
      "type": "n8n-nodes-base.httpRequest",
      "position": [650, 300],
      "parameters": {
        "method": "POST",
        "url": "={{ $node['Normalize Input'].json['api_base_url'] }}/onboarding/start/{{ $node['Normalize Input'].json['employee_id'] }}",
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            { "name": "correlation_id", "value": "={{ $node['Normalize Input'].json['correlation_id'] }}" }
          ]
        }
      }
    },
    {
      "id": "hr-profile",
      "name": "HR Mock: Get Profile",
      "type": "n8n-nodes-base.httpRequest",
      "position": [850, 300],
      "parameters": {
        "method": "GET",
        "url": "={{ $node['Normalize Input'].json['api_base_url'] }}/mock/hr/employees/{{ $node['Normalize Input'].json['employee_id'] }}"
      }
    },
    {
      "id": "training-status",
      "name": "Training Mock: T1-T4",
      "type": "n8n-nodes-base.httpRequest",
      "position": [1050, 300],
      "parameters": {
        "method": "GET",
        "url": "={{ $node['Normalize Input'].json['api_base_url'] }}/mock/training/status/{{ $node['Normalize Input'].json['employee_id'] }}"
      }
    },
    {
      "id": "recommendations",
      "name": "Access Recommender",
      "type": "n8n-nodes-base.httpRequest",
      "position": [1250, 300],
      "parameters": {
        "method": "GET",
        "url": "={{ $node['Normalize Input'].json['api_base_url'] }}/mock/access/recommendations/{{ $node['Normalize Input'].json['employee_id'] }}"
      }
    },
    {
      "id": "llm-employee",
      "name": "LLM/Fallback: Employee Summary",
      "type": "n8n-nodes-base.httpRequest",
      "position": [1450, 300],
      "parameters": {
        "method": "POST",
        "url": "={{ $node['Normalize Input'].json['api_base_url'] }}/mock/llm/messages",
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            { "name": "message_type", "value": "employee_onboarding_summary" },
            { "name": "employee_id", "value": "={{ $node['Normalize Input'].json['employee_id'] }}" },
            { "name": "correlation_id", "value": "={{ $node['Normalize Input'].json['correlation_id'] }}" },
            { "name": "context", "value": "={{ { employee_name: $node['HR Mock: Get Profile'].json.name, role: $node['HR Mock: Get Profile'].json.role, level: $node['HR Mock: Get Profile'].json.level, training_summary: $node['Training Mock: T1-T4'].json.modules.map(m => m.module_id + ':' + m.status).join(', '), recommended_systems_list: $node['Access Recommender'].json.recommendations.filter(r => r.recommendation_type=='recommended').map(r => r.system).join(', '), manager_name: 'Manager' } | toJson }}" }
          ]
        }
      }
    },
    {
      "id": "slack-employee",
      "name": "Slack Mock: Store Employee Message",
      "type": "n8n-nodes-base.httpRequest",
      "position": [1650, 300],
      "parameters": {
        "method": "POST",
        "url": "={{ $node['Normalize Input'].json['api_base_url'] }}/mock/slack/messages",
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            { "name": "channel_or_user", "value": "={{ $node['HR Mock: Get Profile'].json.email }}" },
            { "name": "message_type", "value": "employee_onboarding_summary" },
            { "name": "message", "value": "={{ $node['LLM/Fallback: Employee Summary'].json.message }}" },
            { "name": "metadata", "value": "={{ { employee_id: $node['Normalize Input'].json.employee_id, correlation_id: $node['Normalize Input'].json.correlation_id } | toJson }}" }
          ]
        }
      }
    },
    {
      "id": "employee-selection",
      "name": "Employee Selects Access",
      "type": "n8n-nodes-base.httpRequest",
      "position": [1850, 300],
      "parameters": {
        "method": "POST",
        "url": "={{ $node['Normalize Input'].json['api_base_url'] }}/onboarding/select-access",
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            { "name": "employee_id", "value": "={{ $node['Normalize Input'].json['employee_id'] }}" },
            { "name": "selected_systems", "value": "={{ $node['Normalize Input'].json['selected_systems'] }}" },
            { "name": "correlation_id", "value": "={{ $node['Normalize Input'].json['correlation_id'] }}" },
            { "name": "source", "value": "n8n-workflow" }
          ]
        }
      }
    },
    {
      "id": "create-approval",
      "name": "Create Manager Approval",
      "type": "n8n-nodes-base.httpRequest",
      "position": [2050, 300],
      "parameters": {
        "method": "POST",
        "url": "={{ $node['Normalize Input'].json['api_base_url'] }}/mock/approvals",
        "sendQuery": true,
        "queryParameters": {
          "parameters": [
            { "name": "employee_id", "value": "={{ $node['Normalize Input'].json['employee_id'] }}" },
            { "name": "request_id", "value": "={{ $node['Employee Selects Access'].json.request_id }}" },
            { "name": "manager_id", "value": "={{ $node['HR Mock: Get Profile'].json.manager_id }}" },
            { "name": "correlation_id", "value": "={{ $node['Normalize Input'].json['correlation_id'] }}" }
          ]
        }
      }
    },
    {
      "id": "llm-manager",
      "name": "LLM/Fallback: Manager Message",
      "type": "n8n-nodes-base.httpRequest",
      "position": [2250, 300],
      "parameters": {
        "method": "POST",
        "url": "={{ $node['Normalize Input'].json['api_base_url'] }}/mock/llm/messages",
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            { "name": "message_type", "value": "manager_approval_request" },
            { "name": "employee_id", "value": "={{ $node['Normalize Input'].json['employee_id'] }}" },
            { "name": "correlation_id", "value": "={{ $node['Normalize Input'].json['correlation_id'] }}" },
            { "name": "context", "value": "={{ { manager_name: 'Manager', employee_name: $node['HR Mock: Get Profile'].json.name, role: $node['HR Mock: Get Profile'].json.role, level: $node['HR Mock: Get Profile'].json.level, selected_systems_list: $node['Normalize Input'].json.selected_systems.join(', '), correlation_id: $node['Normalize Input'].json.correlation_id, request_id: $node['Employee Selects Access'].json.request_id } | toJson }}" }
          ]
        }
      }
    },
    {
      "id": "slack-manager",
      "name": "Slack Mock: Store Manager Message",
      "type": "n8n-nodes-base.httpRequest",
      "position": [2450, 300],
      "parameters": {
        "method": "POST",
        "url": "={{ $node['Normalize Input'].json['api_base_url'] }}/mock/slack/messages",
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            { "name": "channel_or_user", "value": "={{ $node['HR Mock: Get Profile'].json.manager_id }}" },
            { "name": "message_type", "value": "manager_approval_request" },
            { "name": "message", "value": "={{ $node['LLM/Fallback: Manager Message'].json.message }}" },
            { "name": "metadata", "value": "={{ { employee_id: $node['Normalize Input'].json.employee_id, approval_id: $node['Create Manager Approval'].json.approval_id, correlation_id: $node['Normalize Input'].json.correlation_id } | toJson }}" }
          ]
        }
      }
    },
    {
      "id": "pre-approval-ticket",
      "name": "Pre-Approval Ticket (Expected Block)",
      "type": "n8n-nodes-base.httpRequest",
      "position": [2650, 300],
      "parameters": {
        "method": "POST",
        "url": "={{ $node['Normalize Input'].json['api_base_url'] }}/mock/itsm/tickets",
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            { "name": "employee_id", "value": "={{ $node['Normalize Input'].json['employee_id'] }}" },
            { "name": "approval_id", "value": "={{ $node['Create Manager Approval'].json.approval_id }}" },
            { "name": "requested_systems", "value": "={{ $node['Normalize Input'].json.selected_systems }}" },
            { "name": "requested_by", "value": "n8n-pre-approval-test" },
            { "name": "idempotency_key", "value": "={{ 'pre_' + $node['Normalize Input'].json.correlation_id }}" },
            { "name": "correlation_id", "value": "={{ $node['Normalize Input'].json.correlation_id }}" }
          ]
        },
        "options": { "response": { "neverError": true } }
      },
      "continueOnFail": true
    },
    {
      "id": "normalize-pre-block",
      "name": "Normalize Pre-Approval Result",
      "type": "n8n-nodes-base.set",
      "position": [2850, 300],
      "parameters": {
        "assignments": {
          "assignments": [
            { "name": "pre_approval_blocked", "value": "={{ $json.status === 403 || $json.error === 'APPROVAL_NOT_APPROVED' || $json.detail === 'APPROVAL_NOT_APPROVED' }}" }
          ]
        }
      }
    },
    {
      "id": "gate-check",
      "name": "Check Pre-Approval Blocked",
      "type": "n8n-nodes-base.if",
      "position": [3050, 300],
      "parameters": {
        "conditions": {
          "conditions": [
            { "leftValue": "={{ $node['Normalize Pre-Approval Result'].json.pre_approval_blocked }}", "rightValue": true, "operator": { "type": "boolean", "operation": "equals" } }
          ]
        }
      }
    },
    {
      "id": "auto-approve-decision",
      "name": "Auto-Approve?",
      "type": "n8n-nodes-base.if",
      "position": [3250, 200],
      "parameters": {
        "conditions": {
          "conditions": [
            { "leftValue": "={{ $node['Normalize Input'].json.auto_approve }}", "rightValue": true, "operator": { "type": "boolean", "operation": "equals" } }
          ]
        }
      }
    },
    {
      "id": "approve-manager",
      "name": "Approve Manager Decision",
      "type": "n8n-nodes-base.httpRequest",
      "position": [3450, 100],
      "parameters": {
        "method": "POST",
        "url": "={{ $node['Normalize Input'].json['api_base_url'] }}/mock/approvals/{{ $node['Create Manager Approval'].json.approval_id }}/approve",
        "sendQuery": true,
        "queryParameters": {
          "parameters": [
            { "name": "decided_by", "value": "={{ $node['HR Mock: Get Profile'].json.manager_id }}" },
            { "name": "decision_reason", "value": "Auto-approved for demo" },
            { "name": "correlation_id", "value": "={{ $node['Normalize Input'].json.correlation_id }}" }
          ]
        }
      }
    },
    {
      "id": "fetch-approval-status",
      "name": "Fetch Approval Status",
      "type": "n8n-nodes-base.httpRequest",
      "position": [3650, 100],
      "parameters": {
        "method": "GET",
        "url": "={{ $node['Normalize Input'].json['api_base_url'] }}/mock/approvals/{{ $node['Create Manager Approval'].json.approval_id }}"
      }
    },
    {
      "id": "normalize-approval",
      "name": "Normalize Approval",
      "type": "n8n-nodes-base.set",
      "position": [3850, 100],
      "parameters": {
        "assignments": {
          "assignments": [
            { "name": "is_approved", "value": "={{ $json.status === 'APPROVED' }}" }
          ]
        }
      }
    },
    {
      "id": "branch-approved",
      "name": "Is Approved?",
      "type": "n8n-nodes-base.if",
      "position": [4050, 100],
      "parameters": {
        "conditions": {
          "conditions": [
            { "leftValue": "={{ $node['Normalize Approval'].json.is_approved }}", "rightValue": true, "operator": { "type": "boolean", "operation": "equals" } }
          ]
        }
      }
    },
    {
      "id": "create-ticket",
      "name": "Create ITSM Ticket (Approved)",
      "type": "n8n-nodes-base.httpRequest",
      "position": [4250, 0],
      "parameters": {
        "method": "POST",
        "url": "={{ $node['Normalize Input'].json['api_base_url'] }}/mock/itsm/tickets",
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            { "name": "employee_id", "value": "={{ $node['Normalize Input'].json.employee_id }}" },
            { "name": "approval_id", "value": "={{ $node['Create Manager Approval'].json.approval_id }}" },
            { "name": "requested_systems", "value": "={{ $node['Normalize Input'].json.selected_systems }}" },
            { "name": "requested_by", "value": "hr-onboarding-agent" },
            { "name": "idempotency_key", "value": "={{ 'tkt_' + $node['Normalize Input'].json.correlation_id }}" },
            { "name": "correlation_id", "value": "={{ $node['Normalize Input'].json.correlation_id }}" }
          ]
        }
      }
    },
    {
      "id": "no-ticket-message",
      "name": "Store No-Ticket Notice",
      "type": "n8n-nodes-base.httpRequest",
      "position": [4250, 200],
      "parameters": {
        "method": "POST",
        "url": "={{ $node['Normalize Input'].json['api_base_url'] }}/mock/slack/messages",
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            { "name": "channel_or_user", "value": "={{ $node['HR Mock: Get Profile'].json.email }}" },
            { "name": "message_type", "value": "access_not_approved" },
            { "name": "message", "value": "Your access request was not approved (status: {{ $node['Fetch Approval Status'].json.status }}). No ticket created." },
            { "name": "metadata", "value": "={{ { employee_id: $node['Normalize Input'].json.employee_id, correlation_id: $node['Normalize Input'].json.correlation_id } | toJson }}" }
          ]
        }
      }
    },
    {
      "id": "fetch-final-status",
      "name": "Fetch Final Onboarding Status",
      "type": "n8n-nodes-base.httpRequest",
      "position": [4450, 0],
      "parameters": {
        "method": "GET",
        "url": "={{ $node['Normalize Input'].json['api_base_url'] }}/onboarding/status/{{ $node['Normalize Input'].json.employee_id }}"
      }
    },
    {
      "id": "fetch-audit",
      "name": "Fetch Audit Events",
      "type": "n8n-nodes-base.httpRequest",
      "position": [4650, 0],
      "parameters": {
        "method": "GET",
        "url": "={{ $node['Normalize Input'].json['api_base_url'] }}/audit/events?correlation_id={{ $node['Normalize Input'].json.correlation_id }}"
      }
    },
    {
      "id": "final-response",
      "name": "Return Final Result",
      "type": "n8n-nodes-base.respondToWebhook",
      "position": [4850, 0],
      "parameters": {
        "responseBody": "={{ { employee_id: $node['Normalize Input'].json.employee_id, correlation_id: $node['Normalize Input'].json.correlation_id, approval_gate_passed: $node['Normalize Pre-Approval Result'].json.pre_approval_blocked, ticket_created: $node['Create ITSM Ticket (Approved)'].json.ticket_id ? true : false, ticket_id: $node['Create ITSM Ticket (Approved)'].json.ticket_id, final_status: $node['Fetch Final Onboarding Status'].json, audit_events: $node['Fetch Audit Events'].json } | toJson }}"
      }
    },
    {
      "id": "gate-failure",
      "name": "Gate Failure Path",
      "type": "n8n-nodes-base.noOp",
      "position": [3250, 400],
      "parameters": {}
    }
  ],
  "connections": {
    "Webhook - New Hire": { "main": [[ { "node": "Normalize Input", "type": "main", "index": 0 } ]] },
    "Normalize Input": { "main": [[ { "node": "Start Onboarding Session", "type": "main", "index": 0 } ]] },
    "Start Onboarding Session": { "main": [[ { "node": "HR Mock: Get Profile", "type": "main", "index": 0 } ]] },
    "HR Mock: Get Profile": { "main": [[ { "node": "Training Mock: T1-T4", "type": "main", "index": 0 } ]] },
    "Training Mock: T1-T4": { "main": [[ { "node": "Access Recommender", "type": "main", "index": 0 } ]] },
    "Access Recommender": { "main": [[ { "node": "LLM/Fallback: Employee Summary", "type": "main", "index": 0 } ]] },
    "LLM/Fallback: Employee Summary": { "main": [[ { "node": "Slack Mock: Store Employee Message", "type": "main", "index": 0 } ]] },
    "Slack Mock: Store Employee Message": { "main": [[ { "node": "Employee Selects Access", "type": "main", "index": 0 } ]] },
    "Employee Selects Access": { "main": [[ { "node": "Create Manager Approval", "type": "main", "index": 0 } ]] },
    "Create Manager Approval": { "main": [[ { "node": "LLM/Fallback: Manager Message", "type": "main", "index": 0 } ]] },
    "LLM/Fallback: Manager Message": { "main": [[ { "node": "Slack Mock: Store Manager Message", "type": "main", "index": 0 } ]] },
    "Slack Mock: Store Manager Message": { "main": [[ { "node": "Pre-Approval Ticket (Expected Block)", "type": "main", "index": 0 } ]] },
    "Pre-Approval Ticket (Expected Block)": { "main": [[ { "node": "Normalize Pre-Approval Result", "type": "main", "index": 0 } ]] },
    "Normalize Pre-Approval Result": { "main": [[ { "node": "Check Pre-Approval Blocked", "type": "main", "index": 0 } ]] },
    "Check Pre-Approval Blocked": {
      "main": [
        [ { "node": "Auto-Approve?", "type": "main", "index": 0 } ],
        [ { "node": "Gate Failure Path", "type": "main", "index": 0 } ]
      ]
    },
    "Auto-Approve?": {
      "main": [
        [ { "node": "Approve Manager Decision", "type": "main", "index": 0 } ],
        [ { "node": "Fetch Approval Status", "type": "main", "index": 0 } ]
      ]
    },
    "Approve Manager Decision": { "main": [[ { "node": "Fetch Approval Status", "type": "main", "index": 0 } ]] },
    "Fetch Approval Status": { "main": [[ { "node": "Normalize Approval", "type": "main", "index": 0 } ]] },
    "Normalize Approval": { "main": [[ { "node": "Is Approved?", "type": "main", "index": 0 } ]] },
    "Is Approved?": {
      "main": [
        [ { "node": "Create ITSM Ticket (Approved)", "type": "main", "index": 0 } ],
        [ { "node": "Store No-Ticket Notice", "type": "main", "index": 0 } ]
      ]
    },
    "Create ITSM Ticket (Approved)": { "main": [[ { "node": "Fetch Final Onboarding Status", "type": "main", "index": 0 } ]] },
    "Store No-Ticket Notice": { "main": [[ { "node": "Fetch Final Onboarding Status", "type": "main", "index": 0 } ]] },
    "Fetch Final Onboarding Status": { "main": [[ { "node": "Fetch Audit Events", "type": "main", "index": 0 } ]] },
    "Fetch Audit Events": { "main": [[ { "node": "Return Final Result", "type": "main", "index": 0 } ]] }
  },
  "active": false,
  "settings": { "executionOrder": "v1", "saveExecutionProgress": true }
}
